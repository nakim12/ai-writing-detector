# Data — never commit raw or processed datasets
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Trained model artifacts
models/*
!models/.gitkeep

# Quarto / Jupyter build output
*_files/
*.html
*.pdf
.quarto/
_site/
_freeze/
.ipynb_checkpoints/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/
.env

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
